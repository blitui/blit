// TestMypkg is a generated test stub. Replace the stub model with a
// real tea.Model from your package and extend the assertions.
func TestMypkg(t *testing.T) {
	// TODO: replace &stubMypkg{} with your model, e.g. mypkg.NewMypkg().
	tm := btest.NewTestModel(t, &stubMypkg{}, 80, 24)

	tm.RequireScreen(func(t testing.TB, s *btest.Screen) {
		if s.String() == "" {
			t.Log("screen is empty — wire up your model and add assertions here")
		}
	})
}

// stubMypkg satisfies tea.Model so the generated file compiles and
// passes go vet immediately without importing the package under test.
type stubMypkg struct{}

func (s *stubMypkg) Init() tea.Cmd                           { return nil }
func (s *stubMypkg) Update(msg tea.Msg) (tea.Model, tea.Cmd) { return s, nil }
func (s *stubMypkg) View() string                            { return "" }
